generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("DEVELOPER")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Product {
  id                  String           @id @default(uuid())
  name                String
  description         String?
  repoUrl             String?
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  deploymentType      String?
  serviceImageName    String?
  azureOrg            String?
  azurePat            String?
  azureProject        String?
  pmType              String?
  azureReleaseProject String?
  apis                Api[]
  moduleGroups        ModuleGroup[]
  modules             Module[]
  versions            ProductVersion[]
  services            Service[]

  @@map("products")
}

model Service {
  id                      String                   @id @default(uuid())
  productId               String
  name                    String
  description             String?
  repoUrl                 String?
  port                    Int?
  isActive                Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  currentVersion          String?
  currentVersionCreatedAt DateTime?
  pipelineName            String?
  releaseName             String?
  repoName                String?
  serviceImageName        String?
  moduleId                String?
  releaseStage            String?
  lastReleaseName         String?
  releaseSnapshots        ServiceReleaseSnapshot[]
  module                  Module?                  @relation(fields: [moduleId], references: [id])
  product                 Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("services")
}

model Api {
  id           String   @id @default(uuid())
  productId    String
  name         String
  path         String
  method       String
  description  String?
  isBreaking   Boolean  @default(false)
  isDeprecated Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("apis")
}

model ModuleGroup {
  id          String   @id @default(uuid())
  productId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  modules     Module[]

  @@map("module_groups")
}

model Module {
  id            String       @id @default(uuid())
  productId     String
  moduleGroupId String?
  name          String
  description   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  moduleGroup   ModuleGroup? @relation(fields: [moduleGroupId], references: [id])
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  services      Service[]

  @@map("modules")
}

model ProductVersion {
  id               String                   @id @default(uuid())
  productId        String
  version          String
  phase            String                   @default("PLANNED")
  targetDate       DateTime?
  releaseDate      DateTime?
  description      String?
  notesPublished   Boolean                  @default(false)
  createdBy        String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  isHotfix         Boolean                  @default(false)
  masterStartDate  DateTime?
  preProdDate      DateTime?
  testDate         DateTime?
  customerMappings CustomerProductMapping[]
  hotfixRequests   HotfixRequest[]
  product          Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  releaseNotes     ReleaseNote[]
  releaseTodos     ReleaseTodo[]
  serviceSnapshots ServiceReleaseSnapshot[]
  systemChanges    SystemChange[]

  @@unique([productId, version])
  @@map("product_versions")
}

model ReleaseNote {
  id               String         @id @default(uuid())
  productVersionId String
  category         String
  title            String
  description      String?
  isBreaking       Boolean        @default(false)
  sortOrder        Int            @default(0)
  createdBy        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  workitemId       String?
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@map("release_notes")
}

model SystemChange {
  id               String          @id @default(uuid())
  productVersionId String?
  apiPath          String?
  changeType       String
  title            String
  description      String?
  previousValue    String?
  newValue         String?
  isBreaking       Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  productVersion   ProductVersion? @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@map("system_changes")
}

model Customer {
  id                   String                   @id @default(uuid())
  name                 String
  code                 String                   @unique
  contactEmail         String?
  contactPhone         String?
  address              String?
  notes                String?
  isActive             Boolean                  @default(true)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  approverEmails       String[]                 @default([])
  azureReleaseTemplate String?
  devOpsEmails         String[]                 @default([])
  emailDomain          String?
  environments         String[]                 @default([])
  supportSuffix        String?
  tenantName           String?
  branches             CustomerBranch[]
  productMappings      CustomerProductMapping[]
  serviceMappings      CustomerServiceMapping[]

  @@map("customers")
}

model CustomerProductMapping {
  id               String         @id @default(uuid())
  customerId       String
  productVersionId String
  branch           String?
  environment      String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  customer         Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id])

  @@unique([customerId, productVersionId])
  @@map("customer_product_mappings")
}

model CustomerServiceMapping {
  id          String   @id @default(uuid())
  customerId  String
  serviceId   String
  port        Int?
  branch      String?
  environment String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_service_mappings")
}

model CustomerBranch {
  id          String        @id @default(uuid())
  customerId  String
  branchName  String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  baseBranch  String?
  isActive    Boolean       @default(true)
  repoName    String?
  repoUrl     String?
  azurePat    String?       // PAT with Code Read+Write+PR Contribute for customer repo
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  syncHistory SyncHistory[]

  @@map("customer_branches")
}

model SyncHistory {
  id               String         @id @default(uuid())
  customerBranchId String
  sourceBranch     String
  targetBranch     String
  status           String
  conflictDetails  Json?
  resolvedBy       String?
  triggeredBy      String?
  completedAt      DateTime?
  createdAt        DateTime       @default(now())
  mergeCommitId    String?
  payload          Json?
  syncBranchName   String?
  customerBranch   CustomerBranch @relation(fields: [customerBranchId], references: [id])

  @@map("sync_history")
}

model HotfixRequest {
  id               String         @id @default(uuid())
  productVersionId String
  title            String
  description      String
  severity         String         @default("MEDIUM")
  status           String         @default("PENDING")
  prUrl            String?
  branchName       String?
  customerImpact   String?
  requestedBy      String
  approvals        Json?
  rejectionReason  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id])

  @@map("hotfix_requests")
}

model ReleaseTodo {
  id               String          @id @default(uuid())
  productVersionId String?
  templateId       String?
  title            String
  description      String?
  category         String          @default("TECHNICAL")
  priority         String          @default("P1")
  isCompleted      Boolean         @default(false)
  completedBy      String?
  completedAt      DateTime?
  sortOrder        Int             @default(0)
  isTemplate       Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  timing           String          @default("PRE")
  productVersion   ProductVersion? @relation(fields: [productVersionId], references: [id])

  @@map("release_todos")
}

model ServiceReleaseSnapshot {
  id               String         @id @default(uuid())
  serviceId        String
  productVersionId String
  releaseName      String?
  releasedAt       DateTime
  prIds            Json
  publishedBy      String?
  notes            String?
  createdAt        DateTime       @default(now())
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id])
  service          Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, releasedAt(sort: Desc)])
  @@map("service_release_snapshots")
}

model UrgentChange {
  id               String    @id @default(uuid())
  title            String
  description      String
  priority         String    @default("MEDIUM")
  status           String    @default("OPEN")
  affectedProducts Json?
  workaroundExists Boolean   @default(false)
  customerImpact   String?
  requestedBy      String
  comments         Json?
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("urgent_changes")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  linkUrl   String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model WorkflowHistory {
  id            String    @id @default(uuid())
  workflowType  String
  n8nWorkflowId String?
  triggeredBy   String?
  status        String
  payload       Json?
  result        Json?
  errorMessage  String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@map("workflow_history")
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  category    String
  isSensitive Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@map("settings")
}
