N8N_RELEASE_NOTES_WEBHOOK_URL=http://localhost:5678/webhook/release-notes-generate
MCP_SERVER_URL=http://localhost:8083
# Backend'in kendi URL'i — n8n'in geri kayıt yapabilmesi için (docker'da host.docker.internal kullan)
BACKEND_URL=http://localhost:3001
TFS_ORG_URL=https://dev.azure.com/your_org
TFS_PAT_TOKEN=
TFS_PROJECT=ReleaseHub360
