PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://releasehub:password@localhost:5432/releasehub360
JWT_SECRET=change_this_in_production_super_secret_key
JWT_REFRESH_SECRET=change_this_refresh_secret_key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
